From: CoFunc TDX artifact reproduction <noreply@example.com>
Date: Mon, 20 Jul 2026 15:10:00 +0000
Subject: [PATCH] Prefault private memory in allocator chunks

Keep private-memory establishment ahead of function launch, but issue one
MapGPA/accept operation per allocator acceptance chunk.  This matches the
granularity used by the proven demand path and avoids one multi-gigabyte
old-ABI MapGPA operation for large workloads.
---
 cvm_os/kernel/split-container/split_container.c | 8 +++++---
 1 file changed, 5 insertions(+), 3 deletions(-)

diff --git a/cvm_os/kernel/split-container/split_container.c b/cvm_os/kernel/split-container/split_container.c
--- a/cvm_os/kernel/split-container/split_container.c
+++ b/cvm_os/kernel/split-container/split_container.c
@@ -275,22 +275,24 @@ static unsigned long prefault_private_mem_pool(void)
         unsigned long size = mem_pool->pool_mem_size;
         unsigned long addr;
         unsigned long gpa;
+        unsigned long chunk_gpa;
         unsigned long t0, t1;
         struct page *hpage;
 
         BUG_ON(start % ACCEPT_PAGE_SIZE);
         BUG_ON(size % ACCEPT_PAGE_SIZE);
 
         gpa = virt_to_phys((void *)start);
         t0 = get_cycles();
-        change_phys_state(gpa, gpa + size, 1);
-        t1 = get_cycles();
-
         for (addr = start; addr < start + size; addr += ACCEPT_PAGE_SIZE) {
+                chunk_gpa = virt_to_phys((void *)addr);
+                change_phys_state(chunk_gpa,
+                                  chunk_gpa + ACCEPT_PAGE_SIZE, 1);
                 hpage = __virt_to_page(mem_pool, (void *)addr);
                 BUG_ON(hpage->sc_accepted);
                 hpage->sc_accepted = 1;
         }
+        t1 = get_cycles();
 
         printk("CoFunc private pre-fault: gpa=0x%lx bytes=%lu chunks=%lu cycles=%lu\n",
                gpa, size, size / ACCEPT_PAGE_SIZE, t1 - t0);
