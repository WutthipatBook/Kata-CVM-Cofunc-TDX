--- a/cvm_os/download_musl.sh
+++ b/cvm_os/download_musl.sh
@@ -1,8 +1,12 @@
 #!/bin/bash -e
 
 path=user/system-services/chcore-libc/musl-libc
-url=git://git.musl-libc.org/musl
+url=https://git.musl-libc.org/git/musl
 branch=v1.2.3
 
