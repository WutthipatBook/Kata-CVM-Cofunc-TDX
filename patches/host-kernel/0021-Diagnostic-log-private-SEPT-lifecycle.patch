+static bool cofunc_tdx_take_log_budget(atomic_t *budget)
+{
+	return atomic_dec_if_positive(budget) >= 0;
+}
+
+static void cofunc_tdx_log_sept_change(struct kvm *kvm, const char *where,
+				       const struct kvm_spte_change *change)
+{
+	struct kvm_tdx *kvm_tdx = to_kvm_tdx(kvm);
+
+	if (!cofunc_tdx_take_log_budget(&cofunc_tdx_sept_change_log_budget))
+		return;
+
+	pr_info("CoFunc old-ABI TDX SEPT change: where=%s gfn=0x%llx level=%u old_pfn=0x%llx old_present=%d old_last=%d old_private_zapped=%d new_pfn=0x%llx new_present=%d new_last=%d new_private_zapped=%d sept_page=%px hkid=%d assigned=%d blocked=%d task=%s/%d\n",
+		where,
+		(unsigned long long)change->gfn,
+		change->level,
+		(unsigned long long)change->old.pfn,
+		change->old.is_present,
+		change->old.is_last,
+		change->old.is_private_zapped,
+		(unsigned long long)change->new.pfn,
+		change->new.is_present,
+		change->new.is_last,
+		change->new.is_private_zapped,
+		change->sept_page,
+		kvm_tdx->hkid,
+		is_hkid_assigned(kvm_tdx),
+		READ_ONCE(kvm_tdx->has_range_blocked),
+		current->comm,
+		current->pid);
+}
+
+static void cofunc_tdx_log_sept_seamcall_failure(struct kvm *kvm,
+						 const char *op, gfn_t gfn,
+						 enum pg_level level,
+						 kvm_pfn_t pfn, u64 err,
+						 const struct tdx_module_output *out)
+{
+	struct kvm_memory_slot *slot = gfn_to_memslot(kvm, gfn);
+	struct kvm_tdx *kvm_tdx = to_kvm_tdx(kvm);
+
+	if (!cofunc_tdx_take_log_budget(&cofunc_tdx_sept_error_log_budget))
+		return;
+
+	pr_err("CoFunc old-ABI TDX SEPT seamcall failure context: op=%s gfn=0x%llx gpa=0x%llx level=%u tdx_level=%d pfn=0x%llx err=0x%llx out_rcx=0x%llx out_rdx=0x%llx out_r8=0x%llx out_r9=0x%llx slot_private=%d hkid=%d assigned=%d blocked=%d task=%s/%d\n",
+	       op, (unsigned long long)gfn, (unsigned long long)gfn_to_gpa(gfn),
+	       level, pg_level_to_tdx_sept_level(level), (unsigned long long)pfn,
+	       err, out ? out->rcx : 0, out ? out->rdx : 0, out ? out->r8 : 0,
+	       out ? out->r9 : 0, slot ? kvm_slot_can_be_private(slot) : -1,
+	       kvm_tdx->hkid, is_hkid_assigned(kvm_tdx),
+	       READ_ONCE(kvm_tdx->has_range_blocked), current->comm, current->pid);
+}
