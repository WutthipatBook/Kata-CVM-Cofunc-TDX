From 0000000000000000000000000000000000000020 Mon Sep 17 00:00:00 2001
From: Codex <codex@local>
Date: Tue, 7 Jul 2026 08:45:00 +0000
Subject: [PATCH] KVM: TDX unblock demoted private SEPT children

Old-ABI CoFunc can now install 2M private SPTEs over normal memslots.
The full Fig.11 run showed that memslot zapping can force KVM to split a
live 2M private leaf and then zap individual 4K child leaves.  The TDX
module reported the child entries as already blocked:

  TDH_MEM_RANGE_BLOCK: TDX_EPT_WALK_FAILED ... level 1, SEPT_BLOCKED
  TDH_MEM_PAGE_REMOVE: TDX_EPT_WALK_FAILED ... level 1, SEPT_BLOCKED

That is consistent with TDH.MEM.PAGE.DEMOTE preserving the blocked state
from the parent large leaf.  KVM, however, has just replaced the large
software SPTE with a present lower-level page table, so the demoted child
SEPT entries need to be unblocked before later code treats them as normal
present child leaves.

Only do this for the live present-large-leaf split path.  The
private-zapped split path intentionally keeps the children blocked.
---
 arch/x86/kvm/vmx/tdx.c | 51 ++++++++++++++++++++++++++++++++++++++----
 1 file changed, 47 insertions(+), 4 deletions(-)

--- a/arch/x86/kvm/vmx/tdx.c
+++ b/arch/x86/kvm/vmx/tdx.c
@@ -2155,8 +2155,11 @@
 
 }
 
-static void tdx_sept_unzap_private_spte(struct kvm *kvm, gfn_t gfn,
-					enum pg_level level)
+static atomic_t cofunc_tdx_demote_unblock_log_budget = ATOMIC_INIT(32);
+
+static bool __tdx_sept_unzap_private_spte(struct kvm *kvm, gfn_t gfn,
+					  enum pg_level level, bool do_track,
+					  bool ignore_not_blocked)
 {
 	int tdx_level = pg_level_to_tdx_sept_level(level);
 	struct kvm_tdx *kvm_tdx = to_kvm_tdx(kvm);
@@ -2164,13 +2167,54 @@
 	struct tdx_module_output out;
 	u64 err;
 
-	tdx_track(kvm_tdx);
+	if (do_track)
+		tdx_track(kvm_tdx);
 
 	spin_lock(&kvm_tdx->seamcall_lock);
 	err = tdh_mem_range_unblock(kvm_tdx->tdr.pa, gpa, tdx_level, &out);
 	spin_unlock(&kvm_tdx->seamcall_lock);
+	if (err && ignore_not_blocked &&
+	    ((err & TDX_SEAMCALL_STATUS_MASK) == TDX_GPA_RANGE_NOT_BLOCKED))
+		return true;
 	if (KVM_BUG_ON(err, kvm))
 		pr_tdx_error(TDH_MEM_RANGE_UNBLOCK, err, &out);
+
+	return !err;
+}
+
+static void tdx_sept_unzap_private_spte(struct kvm *kvm, gfn_t gfn,
+					enum pg_level level)
+{
+	__tdx_sept_unzap_private_spte(kvm, gfn, level, true, false);
+}
+
+static void tdx_sept_unblock_demoted_private_spte(struct kvm *kvm, gfn_t gfn,
+						  enum pg_level level)
+{
+	struct kvm_tdx *kvm_tdx = to_kvm_tdx(kvm);
+	enum pg_level child_level = level - 1;
+	unsigned long child_pages;
+	int i;
+
+	if (WARN_ON(level <= PG_LEVEL_4K))
+		return;
+
+	child_pages = KVM_PAGES_PER_HPAGE(child_level);
+	if (atomic_dec_if_positive(&cofunc_tdx_demote_unblock_log_budget) >= 0)
+		pr_info("CoFunc old-ABI TDX demote child unblock: gfn=0x%llx level=%u child_level=%u entries=%u child_pages=%lu\n",
+			(unsigned long long)gfn, level, child_level,
+			SPTE_ENT_PER_PAGE, child_pages);
+
+	/*
+	 * TDH.MEM.PAGE.DEMOTE inherits the parent's blocked state.  KVM's new
+	 * child SPTEs are present, so unblock the child ranges after a single
+	 * epoch advance.  Ignore NOT_BLOCKED to keep the helper tolerant if a
+	 * TDX module already materializes demoted children as unblocked.
+	 */
+	tdx_track(kvm_tdx);
+	for (i = 0; i < SPTE_ENT_PER_PAGE; i++)
+		__tdx_sept_unzap_private_spte(kvm,
+			gfn + i * child_pages, child_level, false, true);
 }
 
 static int tdx_sept_free_private_sp(struct kvm *kvm, gfn_t gfn, enum pg_level level,
@@ -2343,7 +2387,10 @@
 		if (level > PG_LEVEL_4K && was_leaf && !is_leaf) {
 			tdx_sept_zap_private_spte(kvm, gfn, level);
 			tdx_sept_tlb_remote_flush(kvm);
-			tdx_sept_split_private_spte(kvm, gfn, level, change->sept_page);
+			if (!tdx_sept_split_private_spte(kvm, gfn, level,
+							 change->sept_page))
+				tdx_sept_unblock_demoted_private_spte(kvm, gfn,
+								      level);
 		} else if (is_leaf)
 			tdx_sept_set_private_spte(
 				kvm, gfn, level, change->new.pfn);
