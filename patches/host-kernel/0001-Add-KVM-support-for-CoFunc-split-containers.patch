 }
 
-static void kvm_mmu_notifier_invalidate_range_end(struct mmu_notifier *mn,
+static void __kvm_mmu_notifier_invalidate_range_end(struct kvm *kvm,
+					struct mm_struct *mm,
 					const struct mmu_notifier_range *range)
 {
-	struct kvm *kvm = mmu_notifier_to_kvm(mn);
 	const struct kvm_mmu_notifier_range hva_range = {
 		.start		= range->start,
 		.end		= range->end,
+		.mm		= mm,
 		.handler	= (void *)kvm_null_fn,
 		.on_lock	= kvm_mmu_invalidate_end,
 		.flush_on_ret	= false,
@@ -831,6 +877,13 @@ static void kvm_mmu_notifier_invalidate_range_end(struct mmu_notifier *mn,
 		rcuwait_wake_up(&kvm->mn_memslots_update_rcuwait);
 }
 
+static void kvm_mmu_notifier_invalidate_range_end(struct mmu_notifier *mn,
+					const struct mmu_notifier_range *range)
+{
+	__kvm_mmu_notifier_invalidate_range_end(mmu_notifier_to_kvm(mn),
+						range->mm, range);
+}
+
 static int kvm_mmu_notifier_clear_flush_young(struct mmu_notifier *mn,
 					      struct mm_struct *mm,
 					      unsigned long start,
@@ -838,7 +891,7 @@ static int kvm_mmu_notifier_clear_flush_young(struct mmu_notifier *mn,
 {
 	trace_kvm_age_hva(start, end);
 
-	return kvm_age_hva_range(mn, start, end, kvm_age_gfn,
+	return kvm_age_hva_range(mn, mm, start, end, kvm_age_gfn,
 				 !IS_ENABLED(CONFIG_KVM_ELIDE_TLB_FLUSH_IF_YOUNG));
 }
 
@@ -862,7 +915,7 @@ static int kvm_mmu_notifier_clear_young(struct mmu_notifier *mn,
 	 * cadence. If we find this inaccurate, we might come up with a
 	 * more sophisticated heuristic later.
 	 */
-	return kvm_age_hva_range_no_flush(mn, start, end, kvm_age_gfn);
+	return kvm_age_hva_range_no_flush(mn, mm, start, end, kvm_age_gfn);
 }
 
 static int kvm_mmu_notifier_test_young(struct mmu_notifier *mn,
@@ -871,14 +924,12 @@ static int kvm_mmu_notifier_test_young(struct mmu_notifier *mn,
 {
 	trace_kvm_test_age_hva(address);
 
-	return kvm_age_hva_range_no_flush(mn, address, address + 1,
+	return kvm_age_hva_range_no_flush(mn, mm, address, address + 1,
 					  kvm_test_age_gfn);
 }
 
-static void kvm_mmu_notifier_release(struct mmu_notifier *mn,
-				     struct mm_struct *mm)
+static void __kvm_mmu_notifier_release(struct kvm *kvm)
 {
-	struct kvm *kvm = mmu_notifier_to_kvm(mn);
 	int idx;
 
 	idx = srcu_read_lock(&kvm->srcu);
@@ -886,6 +937,76 @@ static void kvm_mmu_notifier_release(struct mmu_notifier *mn,
 	srcu_read_unlock(&kvm->srcu, idx);
 }
 
+static void kvm_mmu_notifier_release(struct mmu_notifier *mn,
+				     struct mm_struct *mm)
+{
+	__kvm_mmu_notifier_release(mmu_notifier_to_kvm(mn));
+}
+
+static int kvm_sc_mmu_notifier_invalidate_range_start(struct mmu_notifier *mn,
+					const struct mmu_notifier_range *range)
+{
+	struct kvm_sc_mmu_notifier *sc_mn = mmu_notifier_to_sc_mn(mn);
+
+	return __kvm_mmu_notifier_invalidate_range_start(sc_mn->kvm,
+							sc_mn->mm, range);
+}
+
+static void kvm_sc_mmu_notifier_invalidate_range_end(struct mmu_notifier *mn,
+					const struct mmu_notifier_range *range)
+{
+	struct kvm_sc_mmu_notifier *sc_mn = mmu_notifier_to_sc_mn(mn);
+
+	__kvm_mmu_notifier_invalidate_range_end(sc_mn->kvm, sc_mn->mm, range);
+}
+
+static int kvm_sc_mmu_notifier_clear_flush_young(struct mmu_notifier *mn,
+						 struct mm_struct *mm,
+						 unsigned long start,
+						 unsigned long end)
+{
+	struct kvm_sc_mmu_notifier *sc_mn = mmu_notifier_to_sc_mn(mn);
+
+	trace_kvm_age_hva(start, end);
+
+	return __kvm_age_hva_range(sc_mn->kvm, sc_mn->mm, start, end,
+				   kvm_age_gfn,
+				   !IS_ENABLED(CONFIG_KVM_ELIDE_TLB_FLUSH_IF_YOUNG));
+}
+
+static int kvm_sc_mmu_notifier_clear_young(struct mmu_notifier *mn,
+					   struct mm_struct *mm,
+					   unsigned long start,
+					   unsigned long end)
+{
+	struct kvm_sc_mmu_notifier *sc_mn = mmu_notifier_to_sc_mn(mn);
+
+	trace_kvm_age_hva(start, end);
+
+	return __kvm_age_hva_range(sc_mn->kvm, sc_mn->mm, start, end,
+				   kvm_age_gfn, false);
+}
+
+static int kvm_sc_mmu_notifier_test_young(struct mmu_notifier *mn,
+					  struct mm_struct *mm,
+					  unsigned long address)
+{
+	struct kvm_sc_mmu_notifier *sc_mn = mmu_notifier_to_sc_mn(mn);
+
+	trace_kvm_test_age_hva(address);
+
+	return __kvm_age_hva_range(sc_mn->kvm, sc_mn->mm, address,
+				   address + 1, kvm_test_age_gfn, false);
+}
+
+static void kvm_sc_mmu_notifier_release(struct mmu_notifier *mn,
+					struct mm_struct *mm)
+{
+	struct kvm_sc_mmu_notifier *sc_mn = mmu_notifier_to_sc_mn(mn);
+
+	__kvm_mmu_notifier_release(sc_mn->kvm);
+}
+
 static const struct mmu_notifier_ops kvm_mmu_notifier_ops = {
 	.invalidate_range_start	= kvm_mmu_notifier_invalidate_range_start,
 	.invalidate_range_end	= kvm_mmu_notifier_invalidate_range_end,
@@ -895,12 +1016,80 @@ static const struct mmu_notifier_ops kvm_mmu_notifier_ops = {
 	.release		= kvm_mmu_notifier_release,
 };
 
+static const struct mmu_notifier_ops kvm_sc_mmu_notifier_ops = {
+	.invalidate_range_start	= kvm_sc_mmu_notifier_invalidate_range_start,
+	.invalidate_range_end	= kvm_sc_mmu_notifier_invalidate_range_end,
+	.clear_flush_young	= kvm_sc_mmu_notifier_clear_flush_young,
+	.clear_young		= kvm_sc_mmu_notifier_clear_young,
+	.test_young		= kvm_sc_mmu_notifier_test_young,
+	.release		= kvm_sc_mmu_notifier_release,
+};
+
 static int kvm_init_mmu_notifier(struct kvm *kvm)
 {
 	kvm->mmu_notifier.ops = &kvm_mmu_notifier_ops;
 	return mmu_notifier_register(&kvm->mmu_notifier, current->mm);
 }
 
+static int kvm_register_memslot_mmu_notifier(struct kvm *kvm,
+					     struct mm_struct *mm)
+{
+	struct kvm_sc_mmu_notifier *sc_mn;
+	int r;
+
+	if (mm == kvm->mm)
+		return 0;
