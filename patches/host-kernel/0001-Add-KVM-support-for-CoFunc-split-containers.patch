 #ifdef CONFIG_KVM_GENERIC_MMU_NOTIFIER
+struct kvm_sc_mmu_notifier {
+	struct mmu_notifier notifier;
+	struct kvm *kvm;
+	struct mm_struct *mm;
+	struct list_head node;
+};
+
 static inline struct kvm *mmu_notifier_to_kvm(struct mmu_notifier *mn)
 {
 	return container_of(mn, struct kvm, mmu_notifier);
 }
 
+static inline struct kvm_sc_mmu_notifier *
+mmu_notifier_to_sc_mn(struct mmu_notifier *mn)
+{
+	return container_of(mn, struct kvm_sc_mmu_notifier, notifier);
+}
+
+static struct mm_struct *kvm_slot_owner_mm(struct kvm *kvm,
+					   const struct kvm_memory_slot *slot)
+{
+	return slot && slot->userspace_mm ? slot->userspace_mm : kvm->mm;
+}
+
 typedef bool (*gfn_handler_t)(struct kvm *kvm, struct kvm_gfn_range *range);
 
 typedef void (*on_lock_fn_t)(struct kvm *kvm);
@@ -520,6 +540,7 @@ struct kvm_mmu_notifier_range {
 	u64 start;
 	u64 end;
 	union kvm_mmu_notifier_arg arg;
+	struct mm_struct *mm;
 	gfn_handler_t handler;
 	on_lock_fn_t on_lock;
 	bool flush_on_ret;
@@ -594,6 +615,9 @@ static __always_inline kvm_mn_ret_t kvm_handle_hva_range(struct kvm *kvm,
 			unsigned long hva_start, hva_end;
 
 			slot = container_of(node, struct kvm_memory_slot, hva_node[slots->node_idx]);
+			if (range->mm && kvm_slot_owner_mm(kvm, slot) != range->mm)
+				continue;
+
 			hva_start = max_t(unsigned long, range->start, slot->userspace_addr);
 			hva_end = min_t(unsigned long, range->end,
 					slot->userspace_addr + (slot->npages << PAGE_SHIFT));
@@ -648,16 +672,17 @@ static __always_inline kvm_mn_ret_t kvm_handle_hva_range(struct kvm *kvm,
 	return r;
 }
 
-static __always_inline int kvm_age_hva_range(struct mmu_notifier *mn,
