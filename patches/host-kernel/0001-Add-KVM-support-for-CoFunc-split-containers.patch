diff --git a/arch/x86/kvm/Makefile b/arch/x86/kvm/Makefile
index c4b8950c7..da41202a3 100644
--- a/arch/x86/kvm/Makefile
+++ b/arch/x86/kvm/Makefile
@@ -1,6 +1,6 @@
 # SPDX-License-Identifier: GPL-2.0
 
-ccflags-y += -I $(srctree)/arch/x86/kvm
+ccflags-y += -I $(srctree)/arch/x86/kvm -I $(srctree)/virt/kvm
 ccflags-$(CONFIG_KVM_WERROR) += -Werror
 
 include $(srctree)/virt/kvm/Makefile.kvm
diff --git a/arch/x86/kvm/vmx/tdx.c b/arch/x86/kvm/vmx/tdx.c
index 2d7a4d52c..c3d0adab9 100644
--- a/arch/x86/kvm/vmx/tdx.c
+++ b/arch/x86/kvm/vmx/tdx.c
@@ -4,6 +4,7 @@
 #include <asm/cpufeature.h>
 #include <asm/fpu/xcr.h>
 #include <linux/misc_cgroup.h>
+#include <linux/kvm_para.h>
 #include <linux/mmu_context.h>
 #include <asm/tdx.h>
 #include "capabilities.h"
@@ -656,17 +657,14 @@ int tdx_vm_init(struct kvm *kvm)
 	kvm_mmu_set_mmio_spte_value(kvm, 0);
 
 	/*
-	 * TDX has its own limit of maximum vCPUs it can support for all
-	 * TDX guests in addition to KVM_MAX_VCPUS.  TDX module reports
-	 * such limit via the MAX_VCPU_PER_TD global metadata.  In
-	 * practice, it reflects the number of logical CPUs that ALL
-	 * platforms that the TDX module supports can possibly have.
-	 *
-	 * Limit TDX guest's maximum vCPUs to the number of logical CPUs
-	 * the platform has.  Simply forwarding the MAX_VCPU_PER_TD to
-	 * userspace would result in an unpredictable ABI.
+	 * CoFunc keeps a large pool of idle source-CVM vCPUs.  The pool can be
+	 * larger than the host's physical CPU count because those vCPUs block in
+	 * KVM until a clone is assigned.  Advertising num_present_cpus() as the
+	 * hard TDX limit makes the original 128-vCPU workflow fail in QEMU before
+	 * the guest even boots, so use the TDX module's real per-TD limit instead.
 	 */
-	kvm->max_vcpus = min_t(int, kvm->max_vcpus, num_present_cpus());
+	kvm->max_vcpus = min_t(int, kvm->max_vcpus,
+			      tdx_sysinfo->td_conf.max_vcpus_per_td);
 
 	kvm_tdx->state = TD_STATE_UNINITIALIZED;
 
@@ -1161,7 +1159,18 @@ static int tdx_handle_exception_nmi(struct kvm_vcpu *vcpu)
 
 static int complete_hypercall_exit(struct kvm_vcpu *vcpu)
 {
-	tdvmcall_set_return_code(vcpu, vcpu->run->hypercall.ret);
+	switch (vcpu->run->hypercall.nr) {
+	case KVM_HC_SC_VCPU_IDLE:
+	case KVM_HC_TDX_SC_VCPU_IDLE:
+	case KVM_HC_SC_REQUEST:
+	case KVM_HC_TDX_SC_REQUEST:
+		tdvmcall_set_return_code(vcpu, 0);
+		tdvmcall_set_return_val(vcpu, vcpu->run->hypercall.ret);
+		break;
+	default:
+		tdvmcall_set_return_code(vcpu, vcpu->run->hypercall.ret);
+		break;
+	}
 	return 1;
 }
 
diff --git a/arch/x86/kvm/x86.c b/arch/x86/kvm/x86.c
index 63afdb6bb..18367164c 100644
--- a/arch/x86/kvm/x86.c
+++ b/arch/x86/kvm/x86.c
@@ -33,6 +33,7 @@
 #include "lapic.h"
 #include "xen.h"
 #include "smm.h"
+#include "split_container.h"
 
 #include <linux/clocksource.h>
 #include <linux/interrupt.h>
@@ -10438,6 +10439,30 @@ int ____kvm_emulate_hypercall(struct kvm_vcpu *vcpu, int cpl,
 		vcpu->arch.complete_userspace_io = complete_hypercall;
 		return 0;
 	}
+	case KVM_HC_SC_VCPU_IDLE:
+	case KVM_HC_TDX_SC_VCPU_IDLE:
+		split_container_vcpu_idle(vcpu);
+		vcpu->run->exit_reason        = KVM_EXIT_HYPERCALL;
+		vcpu->run->hypercall.nr       = nr;
+		vcpu->run->hypercall.ret      = 0;
+		vcpu->run->hypercall.flags    = 0;
+		if (op_64_bit)
+			vcpu->run->hypercall.flags |= KVM_EXIT_HYPERCALL_LONG_MODE;
+		vcpu->arch.complete_userspace_io = complete_hypercall;
+		return 0;
+	case KVM_HC_SC_REQUEST:
+	case KVM_HC_TDX_SC_REQUEST:
+		vcpu->run->exit_reason        = KVM_EXIT_HYPERCALL;
+		vcpu->run->hypercall.nr       = nr;
+		vcpu->run->hypercall.ret      = 0;
+		vcpu->run->hypercall.args[0]  = a0;
+		vcpu->run->hypercall.args[1]  = a1;
+		vcpu->run->hypercall.args[2]  = a2;
+		vcpu->run->hypercall.flags    = 0;
+		if (op_64_bit)
+			vcpu->run->hypercall.flags |= KVM_EXIT_HYPERCALL_LONG_MODE;
+		vcpu->arch.complete_userspace_io = complete_hypercall;
+		return 0;
 	default:
 		ret = -KVM_ENOSYS;
 		break;
