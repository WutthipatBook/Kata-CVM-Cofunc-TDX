diff --git a/virt/kvm/split_container.c b/virt/kvm/split_container.c
new file mode 100644
index 000000000..99f8daf97
--- /dev/null
+++ b/virt/kvm/split_container.c
@@ -0,0 +1,97 @@
+// SPDX-License-Identifier: GPL-2.0
+#include "split_container.h"
+
+#define MAX_N_KVMS 256
+
+static DEFINE_MUTEX(split_container_kvms_lock);
+static struct kvm *split_container_kvms[MAX_N_KVMS];
+
+void split_container_vm_init(struct kvm *kvm)
+{
+	spin_lock_init(&kvm->sc_idle_vcpus_lock);
+	INIT_LIST_HEAD(&kvm->sc_idle_vcpus);
+}
+
+int split_container_vm_register(struct kvm *kvm, unsigned int slot_id)
+{
+	int ret = 0;
+
+	if (slot_id >= MAX_N_KVMS)
+		return -EINVAL;
+
+	mutex_lock(&split_container_kvms_lock);
+	if (split_container_kvms[slot_id])
+		ret = -EBUSY;
+	else
+		split_container_kvms[slot_id] = kvm;
+	mutex_unlock(&split_container_kvms_lock);
+
+	return ret;
+}
+
+void split_container_vm_destroy(struct kvm *kvm)
+{
+	int i;
+
+	mutex_lock(&split_container_kvms_lock);
+	for (i = 0; i < MAX_N_KVMS; i++) {
+		if (split_container_kvms[i] == kvm)
+			split_container_kvms[i] = NULL;
+	}
+	mutex_unlock(&split_container_kvms_lock);
+}
+
+struct kvm *split_container_vm_get(unsigned int slot_id)
+{
+	struct kvm *kvm = NULL;
+
+	if (slot_id >= MAX_N_KVMS)
+		return NULL;
+
+	mutex_lock(&split_container_kvms_lock);
+	kvm = split_container_kvms[slot_id];
+	if (kvm && !kvm_get_kvm_safe(kvm))
+		kvm = NULL;
+	mutex_unlock(&split_container_kvms_lock);
+
+	return kvm;
+}
+
+void split_container_vcpu_idle(struct kvm_vcpu *vcpu)
+{
+	struct kvm *kvm = vcpu->kvm;
+
+	spin_lock(&kvm->sc_idle_vcpus_lock);
+	if (!READ_ONCE(vcpu->sc_idle)) {
+		WRITE_ONCE(vcpu->sc_idle, true);
+		list_add(&vcpu->sc_idle_node, &kvm->sc_idle_vcpus);
+	}
+	spin_unlock(&kvm->sc_idle_vcpus_lock);
+}
+EXPORT_SYMBOL_GPL(split_container_vcpu_idle);
+
+bool split_container_vcpu_is_idle(struct kvm_vcpu *vcpu)
+{
+	return READ_ONCE(vcpu->sc_idle);
+}
+
+struct kvm_vcpu *split_container_vcpu_alloc(struct kvm *kvm)
+{
+	struct kvm_vcpu *vcpu;
+
+	if (!kvm)
+		return NULL;
+
+	spin_lock(&kvm->sc_idle_vcpus_lock);
+	if (list_empty(&kvm->sc_idle_vcpus)) {
+		vcpu = NULL;
+	} else {
+		vcpu = list_first_entry(&kvm->sc_idle_vcpus,
+					struct kvm_vcpu, sc_idle_node);
+		list_del_init(&vcpu->sc_idle_node);
+		WRITE_ONCE(vcpu->sc_idle, false);
+	}
+	spin_unlock(&kvm->sc_idle_vcpus_lock);
+
+	return vcpu;
+}
diff --git a/virt/kvm/split_container.h b/virt/kvm/split_container.h
new file mode 100644
index 000000000..de0824b79
--- /dev/null
+++ b/virt/kvm/split_container.h
@@ -0,0 +1,19 @@
+/* SPDX-License-Identifier: GPL-2.0 */
+#ifndef __KVM_SPLIT_CONTAINER_H
+#define __KVM_SPLIT_CONTAINER_H
+
+#include <linux/kvm_host.h>
+
+#define KVM_VM_TYPE_SC_MASK		0xff000000UL
+#define KVM_VM_TYPE_SC_SLOT_ID(type)	((((type) >> 24) - 1) & 0xff)
+
+void split_container_vm_init(struct kvm *kvm);
+int split_container_vm_register(struct kvm *kvm, unsigned int slot_id);
+void split_container_vm_destroy(struct kvm *kvm);
+struct kvm *split_container_vm_get(unsigned int slot_id);
+
+void split_container_vcpu_idle(struct kvm_vcpu *vcpu);
+bool split_container_vcpu_is_idle(struct kvm_vcpu *vcpu);
+struct kvm_vcpu *split_container_vcpu_alloc(struct kvm *kvm);
+
+#endif /* __KVM_SPLIT_CONTAINER_H */
