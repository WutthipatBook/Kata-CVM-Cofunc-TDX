From 66d2090bc2e251b5eb8bd6793e47b5c798c6f015 Mon Sep 17 00:00:00 2001
From: Codex <codex@local>
Date: Tue, 7 Jul 2026 04:00:00 +0000
Subject: [PATCH] KVM: Diagnostic clear old-ABI private fault release flags

The TDX unpin cleanup diagnostic did not eliminate old-ABI bad-page reports:
after a clean smoke gate, later allocator churn still found pages on the free
list with PG_referenced and PG_dirty set.  That points at the earlier KVM page
fault release edge: old-ABI private faults use normal memslots, so the generic
kvm_release_pfn_clean() path can mark the PFN accessed while the TDX private
SPTE keeps the page pinned.

For old-ABI private faults in non-private memslots, clear PG_referenced and
PG_dirty across the final mapped range and release the clean PFN without KVM's
normal accessed marking.  This is deliberately scoped to the legacy
private-in-normal-memslot shape and leaves modern private memslots unchanged.
---
 arch/x86/kvm/mmu/mmu.c | 41 +++++++++++++++++++++++++++++++++++++++++
 1 file changed, 41 insertions(+)

--- a/arch/x86/kvm/mmu/mmu.c
+++ b/arch/x86/kvm/mmu/mmu.c
@@ -4835,6 +4835,45 @@ static bool is_page_fault_stale(struct kvm_vcpu *vcpu,
 	       mmu_updating_retry_gfn(vcpu->kvm, mmu_seq, fault->gfn);
 }
 
+static bool cofunc_tdx_oldabi_release_private_fault_pfn_clean(struct kvm_page_fault *fault)
+{
+	struct page *release_page;
+	struct page *page;
+	enum pg_level level = fault->goal_level;
+	int nr_pages;
+	int i;
+
+	/*
+	 * CoFunc old-ABI private fault release page-flag cleanup diagnostic.
+	 *
+	 * Legacy userspace maps private TD pages through normal memslots.  Do
+	 * not let KVM's clean release helper mark those pages accessed while a
+	 * TDX private SPTE can keep the underlying page alive.
+	 */
+	if (!fault->is_private ||
+	    !fault->slot ||
+	    kvm_slot_can_be_private(fault->slot) ||
+	    is_error_noslot_pfn(fault->pfn))
+		return false;
+
+	release_page = kvm_pfn_to_refcounted_page(fault->pfn);
+	if (!release_page)
+		return false;
+
+	if (level < PG_LEVEL_4K || level > KVM_MAX_HUGEPAGE_LEVEL)
+		level = PG_LEVEL_4K;
+
+	nr_pages = KVM_PAGES_PER_HPAGE(level);
+	for (i = 0; i < nr_pages; i++) {
+		page = pfn_to_page(fault->pfn + i);
+		ClearPageReferenced(page);
+		ClearPageDirty(page);
+	}
+
+	put_page(release_page);
+	return true;
+}
+
 static int direct_page_fault(struct kvm_vcpu *vcpu, struct kvm_page_fault *fault)
 {
 	bool is_tdp_mmu_fault = is_tdp_mmu(vcpu->arch.mmu);
@@ -4881,8 +4915,10 @@ out_unlock:
 		write_unlock(&vcpu->kvm->mmu_lock);
 
 	if (kvm_slot_can_be_private(fault->slot))
 		kvm_private_mem_put_pfn(fault->slot, fault->pfn);
+	else if (cofunc_tdx_oldabi_release_private_fault_pfn_clean(fault))
+		;
 	else
 		kvm_release_pfn_clean(fault->pfn);
 	return r;
 }
